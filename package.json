{
  "name": "cookie-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:full": "npm run build && wrangler pages dev dist --local --proxy 3000 --port 8788",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pages:dev": "wrangler pages dev dist",
    "seed:recipes:mediterranean": "node scripts/fetch-recipe-api-recipes.mjs --limit=12",
    "seed:recipes:themealdb:mediterranean": "node scripts/fetch-themealdb-recipes.mjs --limit=24",
    "scrape:recipes": "node scripts/scrape-recipes.mjs",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@react-pdf/renderer": "^4.5.1",
    "@tailwindcss/vite": "^4.1.14",
    "@use-gesture/react": "^10.3.1",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.17",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.4",
    "wrangler": "^3.99.0",
    "zod": "^4.4.3"
  }
}
