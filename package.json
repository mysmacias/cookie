{
  "name": "cookie-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "npm run build --prefix plugins/cookie-recipe-intelligence && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "render:app-icon": "node scripts/render-app-icon.mjs",
    "cap:sync:ios": "npx cap sync ios && node scripts/post-cap-sync-ios.mjs",
    "screenshots:appstore": "npm run build && tsx scripts/app-store-screenshots.ts"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@react-pdf/renderer": "^4.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@use-gesture/react": "^10.3.1",
    "@vitejs/plugin-react": "^5.0.4",
    "cookie-recipe-intelligence": "file:plugins/cookie-recipe-intelligence",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "playwright": "^1.52.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.2"
  }
}
